---
// src/pages/blog/index.astro

const postModules = import.meta.glob('./*.md', { eager: true });

const posts = Object.entries(postModules)
  .map(([filepath, mod]: [string, any]) => {
    const slug = filepath.replace(/^\.\//, '').replace(/\.md$/, '');
    return {
      url: `/blog/${slug}/`,
      title: mod.frontmatter?.title ?? slug,
      date: mod.frontmatter?.date ?? '',
      category: mod.frontmatter?.category ?? '',
    };
  })
  .sort((a, b) => (a.date > b.date ? -1 : 1));

const categories = ['All', ...new Set(posts.map((p) => p.category).filter(Boolean))];
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Blog — Super Hiko14.me</title>
    <meta name="description" content="Super Hiko14のブログです。" />
    <link rel="icon" href="https://super-hiko14.me/favicon.ico" />
    <link rel="icon" type="image/png" href="https://super-hiko14.me/favicon.png" />
    <link rel="stylesheet" href="https://super-hiko14.com/main.css" />
    <link rel="canonical" href="https://super-hiko14.com/blog/" />
    <script src="https://super-hiko14.com/main.js"></script>
  </head>

  <body>
    <nav class="site-nav" aria-label="サイトナビゲーション">
      <button class="site-nav-toggle" aria-label="メニューを開く" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
      <div class="site-nav-drawer" aria-hidden="true">
        <ul></ul>
      </div>
    </nav>

    <main class="container blog-page">
      <!-- ヘッダー -->
      <div class="box">
        <p class="page-eyebrow">super-hiko14.me/blog/</p>
        <h1 class="title">Blog</h1>
        <p class="sub-title">多分不定期更新</p>
      </div>

      <!-- フィルター & 検索 -->
      <div class="box">
        <div class="blog-controls">
          <div class="search-box">
            <input
              type="text"
              id="blog-search"
              placeholder="記事を検索..."
              autocomplete="off"
            />
          </div>
          <div class="filter-buttons" role="group" aria-label="カテゴリフィルター">
            {categories.map((cat) => (
              <button
                class:list={['filter-btn', cat === 'All' && 'active']}
                data-category={cat}
              >
                {cat}
              </button>
            ))}
          </div>
        </div>
      </div>

      <!-- 記事一覧 タイムライン -->
      <div class="box">
        <div class="blog-list" id="blog-list">
          {posts.map((post) => (
            <div
              class="blog-entry"
              data-category={post.category ?? ''}
              data-title={post.title ?? ''}
            >
              {/* 上線 + ドット（日付と同じ行） */}
              <div class="blog-entry-axis">
                <div class="blog-axis-line--top"></div>
                <div class="blog-axis-dot"></div>
              </div>

              {/* 日付（ドットの右に左寄せ） */}
              <div class="blog-entry-meta">
                <span class="blog-entry-date">{post.date}</span>
              </div>

              {/* 下線（カードの左を流れる） */}
              <div class="blog-entry-line">
                <div class="blog-axis-line--bottom"></div>
              </div>

              {/* カード */}
              <div class="blog-entry-card-wrap">
                <a href={post.url} class="blog-item">
                  <span class="blog-item-title">{post.title}</span>
                  {post.category && (
                    <span class="blog-item-category">{post.category}</span>
                  )}
                </a>
              </div>
            </div>
          ))}
        </div>
        <p class="no-results" id="no-results" style="display:none;">
          記事が見つかりませんでした。
        </p>
      </div>

    <div class="box">
      <div class="footer">
        <div class="footer-top">
          <nav class="footer-nav" aria-label="フッターナビゲーション">
            <div class="footer-nav-group">
              <span class="footer-nav-label">法的情報</span>
              <a href="https://legal.super-hiko14.com/terms">利用規約</a>
              <a href="https://legal.super-hiko14.com/privacypolicy">プライバシーポリシー</a>
            </div>
          </nav>
          <div class="footer-controls">
            <button class="theme-toggle" aria-label="テーマ切り替え">
              <img src="https://super-hiko14.com/sozai/images/moon.webp" alt="ダークモード" class="theme-icon-light">
              <img src="https://super-hiko14.com/sozai/images/sun.webp" alt="ライトモード" class="theme-icon-dark">
            </button>
            <button class="scroll-to-top" aria-label="トップへ戻る">
              <img src="https://super-hiko14.com/sozai/images/top_light.webp" alt="トップへ" class="scroll-icon-light">
              <img src="https://super-hiko14.com/sozai/images/top_dark.webp" alt="トップへ" class="scroll-icon-dark">
            </button>
          </div>
        </div>
        <div class="footer-bottom">
          <p>© 2026 Super Hiko14 All rights reserved.</p>
        </div>
        <div class="footer-credit" aria-label="Created by Super Hiko14">
          <div class="footer-credit-label">Created by</div>
          <div class="footer-credit-main">Super Hiko14<span class="footer-credit-dot">.</span></div>
        </div>
      </div>
    </div>
    </main>

    <script>
      const searchInput = document.getElementById('blog-search') as HTMLInputElement;
      const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
      const entries = document.querySelectorAll<HTMLElement>('.blog-entry');
      const noResults = document.getElementById('no-results')!;

      let activeCategory = 'All';

      function applyFilters() {
        const query = searchInput.value.trim().toLowerCase();
        let visible = 0;

        entries.forEach((entry) => {
          const category = entry.dataset.category ?? '';
          const title = entry.dataset.title?.toLowerCase() ?? '';
          const matchCat = activeCategory === 'All' || category === activeCategory;
          const matchSearch = query === '' || title.includes(query);

          if (matchCat && matchSearch) {
            entry.style.display = '';
            visible++;
          } else {
            entry.style.display = 'none';
          }
        });

        noResults.style.display = visible === 0 ? '' : 'none';
      }

      filterBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
          filterBtns.forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
          activeCategory = btn.dataset.category ?? 'All';
          applyFilters();
        });
      });

      searchInput.addEventListener('input', applyFilters);
    </script>
  </body>
</html>